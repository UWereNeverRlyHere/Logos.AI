@{
    ViewBag.Title = "RAG Search";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    .card-header {
        background: lavender;
        font-weight: bold;
    }
</style>

<div class="container py-5">
    <h2 class="text-center mb-4">🔍 RAG Search Portal in .NET</h2>
    <h5 class="text-center mb-4 text-muted">[.NET 9, OpenAI Embedding, Qdrant Vector DB, Semantic Search, Data Source - PDF]</h5>
    <hr />

    <div class="row">
        <div class="col-md-3">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-info text-white">📚 Indexed Sources</div>
                <ul class="list-group list-group-flush" id="indexed-sources-list">
                    @if (ViewBag.AllDocuments != null && ViewBag.AllDocuments.Count > 0)
                    {
                        foreach (var source in ViewBag.AllDocuments)
                        {
                            <li class="list-group-item">
                                <strong>@source.DocumentTitle</strong>
                                <br />
                                <small class="text-muted">@source.FileName</small>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="list-group-item text-muted">No documents indexed yet.</li>
                    }
                </ul>
            </div>
        </div>

        <div class="col-md-9">
            
            <div class="card shadow-sm mb-4 border-success">
                <div class="card-header bg-success text-white">📤 Upload Knowledge Base (Folder)</div>
                <div class="card-body">
                    <form id="uploadForm" onsubmit="uploadFiles(event)">
                        <div class="mb-3">
                            <label class="form-label text-muted">Оберіть папку, що містить PDF-протоколи або статті. Система автоматично відкине файли інших форматів, розіб'є PDF на чанки та векторизує їх у Qdrant.</label>
    
                            <div class="input-group">
                                <label class="btn btn-outline-primary mb-0" for="fileInput" style="cursor: pointer;">
                                    <i class="bi bi-folder2-open"></i> Choose Folder
                                </label>
        
                                <input type="text" id="fileDisplay" class="form-control bg-white" placeholder="No folder chosen..." readonly onclick="document.getElementById('fileInput').click();" style="cursor: pointer;">
        
                                <input type="file" id="fileInput" name="files" accept=".pdf" webkitdirectory directory multiple required style="display: none;" onchange="updateFileDisplay(this)" />
                            </div>
                        </div>
                        <button type="submit" class="btn btn-success w-100" id="uploadBtn">
                            <i class="bi bi-cloud-arrow-up-fill"></i> Upload & Index
                        </button>
                    </form>
                </div>
            </div>

            <div id="loader-section" class="text-center my-4" style="display: none;">
                <div class="spinner-border text-success" style="width: 3rem; height: 3rem;" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <h5 class="mt-3 text-secondary">ШІ читає документи, б'є на чанки та генерує ембеддінги...</h5>
                <h5 class="text-success fw-bold">Час очікування: <span id="timer">0</span> сек</h5>
            </div>

            <div id="upload-result-container" class="mb-4"></div>

            <div class="card shadow-sm mb-4 border-dark">
                <div class="card-header bg-dark text-white">🔎 Semantic Search in Vector DB</div>
                <div class="card-body">
                    <form id="searchForm" onsubmit="performSearch(event)">
                        <div class="input-group mb-3">
                            <input type="text" id="searchQuery" name="question" class="form-control form-control-lg" placeholder="Введіть фразу або декілька через кому (напр. Гіпертонія, Аспірин)..." required />
                            <button type="submit" class="btn btn-primary px-4" id="searchBtn">
                                <i class="bi bi-search"></i> Search
                            </button>
                        </div>
                    </form>

                    <div id="search-loader" class="text-center my-4" style="display: none;">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <h6 class="text-primary mt-2">Виконується пошук по векторній базі Qdrant...</h6>
                    </div>

                    <div id="search-result-container"></div>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
    let timerInterval;
    let secondsPassed = 0;

    function startTimer() {
        secondsPassed = 0;
        document.getElementById('timer').innerText = secondsPassed;
        document.getElementById('loader-section').style.display = 'block';
        document.getElementById('upload-result-container').innerHTML = ''; // Очищаємо старий результат
        document.getElementById('uploadBtn').disabled = true;

        timerInterval = setInterval(() => {
            secondsPassed++;
            document.getElementById('timer').innerText = secondsPassed;
        }, 1000);
    }

    function stopTimer() {
        clearInterval(timerInterval);
        document.getElementById('loader-section').style.display = 'none';
        document.getElementById('uploadBtn').disabled = false;
    }

    async function uploadFiles(event) {
        event.preventDefault(); // Зупиняємо стандартну поведінку форми (перезавантаження сторінки)

        const fileInput = document.getElementById('fileInput');
        if (fileInput.files.length === 0) {
            alert("Оберіть папку з PDF файлами.");
            return;
        }

        const formData = new FormData();
        for (let i = 0; i < fileInput.files.length; i++) {
            formData.append('files', fileInput.files[i]);
        }

        startTimer();

        try {
            const response = await fetch('/rag/upload', {
                method: 'POST',
                body: formData
            });

            const data = await response.json();
            stopTimer();

            if (response.ok) {
                renderUploadResult(data);
                refreshSidebar(); // Фонове оновлення меню зліва!
                fileInput.value = ""; // Очищаємо інпут
                document.getElementById('fileDisplay').value = "";
            } else {
                document.getElementById('upload-result-container').innerHTML = 
                    `<div class="alert alert-danger"><strong>Помилка:</strong> ${data.error || 'Unknown error'}</div>`;
            }
        } catch (error) {
            stopTimer();
            document.getElementById('upload-result-container').innerHTML = 
                `<div class="alert alert-danger"><strong>Network Error:</strong> ${error.message}</div>`;
        }
    }

    // Фонове оновлення списку документів
    async function refreshSidebar() {
        try {
            const response = await fetch('/rag/documents');
            if (response.ok) {
                const docs = await response.json();
                const list = document.getElementById('indexed-sources-list');
                list.innerHTML = '';
                
                if (docs.length === 0) {
                    list.innerHTML = '<li class="list-group-item text-muted">No documents indexed yet.</li>';
                } else {
                    docs.forEach(doc => {
                        list.innerHTML += `<li class="list-group-item">
                                            <strong>${doc.documentTitle}</strong><br />
                                            <small class="text-muted">${doc.fileName}</small>
                                           </li>`;
                    });
                }
            }
        } catch (e) {
            console.error("Failed to refresh sidebar", e);
        }
    }
    function updateFileDisplay(input) {
        const display = document.getElementById('fileDisplay');
        if (input.files && input.files.length > 0) {
            display.value = `Selected files: ${input.files.length}`;
        } else {
            display.value = '';
        }
    }
    async function performSearch(event) {
        event.preventDefault();

        const query = document.getElementById('searchQuery').value;
        if (!query.trim()) return;

        const btn = document.getElementById('searchBtn');
        const loader = document.getElementById('search-loader');
        const container = document.getElementById('search-result-container');

        // Блокуємо кнопку та показуємо спінер
        btn.disabled = true;
        loader.style.display = 'block';
        container.innerHTML = '';

        const formData = new FormData();
        formData.append('question', query);

        try {
            const response = await fetch('/rag/search', {
                method: 'POST',
                body: formData
            });

            const data = await response.json();

            if (response.ok) {
                renderSearchResult(data);
            } else {
                container.innerHTML = `<div class="alert alert-danger"><strong>Помилка:</strong> ${data.error || 'Unknown error'}</div>`;
            }
        } catch (error) {
            container.innerHTML = `<div class="alert alert-danger"><strong>Network Error:</strong> ${error.message}</div>`;
        } finally {
            // Розблоковуємо інтерфейс
            btn.disabled = false;
            loader.style.display = 'none';
        }
    }

    function renderSearchResult(results) {
        if (!results || results.length === 0) {
            document.getElementById('search-result-container').innerHTML = '<div class="alert alert-warning">Нічого не знайдено.</div>';
            return;
        }

        let html = '';

        // Проходимось по кожному запиту (якщо користувач ввів через кому декілька)
        results.forEach(res => {
            html += `<div class="card mb-4 border-info shadow-sm">
                        <div class="card-header bg-info text-dark d-flex justify-content-between align-items-center fw-bold">
                            <span><i class="bi bi-search"></i> Запит: "${res.query}"</span>
                            <span class="badge bg-light text-dark border">Середній Score: ${res.averageScore.toFixed(3)} | Чанків: ${res.totalChunksFound} | Час: ${res.durationSeconds.toFixed(2)}с</span>
                        </div>
                        <div class="card-body bg-light p-3">`;

            if (res.foundChunks && res.foundChunks.length > 0) {
                html += `<div class="list-group">`;

                // Проходимось по знайдених фрагментах тексту (чанках)
                res.foundChunks.forEach(chunk => {
                    // Колір бейджа залежить від впевненості (Score)
                    let badgeClass = chunk.score > 0.8 ? 'bg-success' : (chunk.score > 0.7 ? 'bg-warning text-dark' : 'bg-secondary');

                    html += `
                        <div class="list-group-item list-group-item-action flex-column align-items-start mb-2 shadow-sm border rounded">
                            <div class="d-flex w-100 justify-content-between align-items-center mb-2">
                                <h6 class="mb-0 text-primary fw-bold"><i class="bi bi-file-earmark-medical"></i> ${chunk.documentTitle || 'Невідомий документ'}</h6>
                                <span class="badge ${badgeClass} fs-6">Score: ${chunk.score.toFixed(3)}</span>
                            </div>
                            <p class="mb-2 text-dark" style="white-space: pre-wrap; font-size: 0.95rem;">${chunk.content}</p>
                            <div class="text-muted small d-flex justify-content-between">
                                <span><strong>Файл:</strong> ${chunk.fileName}</span>
                                <span><strong>Сторінка:</strong> ${chunk.pageNumber}</span>
                            </div>
                        </div>
                    `;
                });
                html += `</div>`;
            } else {
                html += `<div class="text-muted text-center my-3"><i class="bi bi-info-circle"></i> Для цього запиту не знайдено релевантних фрагментів у базі.</div>`;
            }

            html += `</div></div>`;
        });

        document.getElementById('search-result-container').innerHTML = html;
    }
    function renderUploadResult(data) {
        let html = `
            <div class="alert alert-success fs-5 shadow-sm text-center">
                <i class="bi bi-check-circle-fill"></i> Індексацію бази знань успішно завершено за <strong>${data.totalProcessingTimeSeconds.toFixed(2)}</strong> сек.
            </div>
            
            <div class="row text-center mb-3">
                <div class="col-md-3">
                    <div class="card shadow-sm border-0 bg-light">
                        <div class="card-body">
                            <h3 class="text-primary fw-bold mb-0">${data.totalDocuments}</h3>
                            <p class="text-muted small mb-0">Всього файлів</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card shadow-sm border-0 bg-light">
                        <div class="card-body">
                            <h3 class="text-success fw-bold mb-0">${data.totalNewDocuments}</h3>
                            <p class="text-muted small mb-0">Нових додано</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card shadow-sm border-0 bg-light">
                        <div class="card-body">
                            <h3 class="text-warning fw-bold mb-0">${data.totalExistingDocuments}</h3>
                            <p class="text-muted small mb-0">Вже існували (Скіпнуто)</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card shadow-sm border-0 bg-light">
                        <div class="card-body">
                            <h3 class="text-danger fw-bold mb-0">${data.failedDocuments}</h3>
                            <p class="text-muted small mb-0">Помилок</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-primary shadow-sm">
                <div class="card-header bg-primary text-white">📊 Обчислювальні витрати (Bulk Ingestion Details)</div>
                <div class="card-body">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            Згенеровано текстових чанків (Knowledge Chunks)
                            <span class="badge bg-secondary rounded-pill fs-6">${data.chunksCount}</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            Витрачено Input токенів (OpenAI Embeddings)
                            <span class="badge bg-primary rounded-pill fs-6">${data.fullInputTokenCount}</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            Всього токенів оброблено
                            <span class="badge bg-dark rounded-pill fs-6">${data.fullTotalTokenCount}</span>
                        </li>
                    </ul>
                </div>
            </div>
        `;
        document.getElementById('upload-result-container').innerHTML = html;
    }
</script>